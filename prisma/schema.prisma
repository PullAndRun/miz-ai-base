generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model VtbStreamer {
  mid           BigInt    @id
  name          String
  liveRoom      BigInt?   @map("live_room")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("vtb_streamers")
}

model VtbLiveSession {
  streamerMid    BigInt       @id @map("streamer_mid")
  streamerName   String       @map("streamer_name")
  liveRoom       BigInt?      @map("live_room")
  startedAt      DateTime     @map("live_started_at")
  startFans      Int?         @map("start_fans")
  deliveredGroupIds String[]  @default([]) @map("delivered_group_ids")
  endDeliveredGroupIds String[] @default([]) @map("end_delivered_group_ids")
  endedAt        DateTime?    @map("ended_at")
  endFans        Int?         @map("end_fans")

  @@map("vtb_live_sessions")
}

model VtbDynamicState {
  streamerMid      BigInt    @id @map("streamer_mid")
  lastPublishedAt  DateTime  @map("last_published_at")
  deliveredGroupIds String[] @default([]) @map("delivered_group_ids")

  @@map("vtb_dynamic_status")
}

model NewsDelivery {
  targetKey    String   @map("target_key")
  newsId       String   @map("news_id")
  deliveredAt  DateTime @default(now()) @map("delivered_at")

  @@id([targetKey, newsId])
  @@index([targetKey, deliveredAt])
  @@map("news_deliveries")
}

model Reminder {
  id          Int      @id @default(autoincrement())
  groupId     String   @map("group_id")
  creatorId   String   @map("creator_id")
  targetId    String   @map("target_id")
  content     String
  remindAt    DateTime @map("remind_at")
  sentAt      DateTime? @map("sent_at")
  lastSentAt  DateTime? @map("last_sent_at")
  repeatIntervalMinutes Int? @map("repeat_interval_minutes")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([sentAt, remindAt])
  @@map("reminders")
}

model ScheduleEvent {
  id          Int       @id @default(autoincrement())
  groupId     String    @map("group_id")
  displayId   Int       @map("display_id")
  creatorId   String    @map("creator_id")
  content     String
  eventAt     DateTime  @map("event_at")
  remindAt    DateTime  @map("remind_at")
  remindedAt  DateTime? @map("reminded_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([groupId, displayId])
  @@index([remindedAt, remindAt])
  @@index([groupId, eventAt])
  @@map("schedule_events")
}

model Activity {
  id            Int                    @id @default(autoincrement())
  groupId       String                 @map("group_id")
  displayId     Int                    @map("display_id")
  creatorId     String                 @map("creator_id")
  content       String
  eventAt       DateTime               @map("event_at")
  remindAt      DateTime               @map("remind_at")
  remindedAt    DateTime?              @map("reminded_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  registrations ActivityRegistration[]

  @@unique([groupId, displayId])
  @@index([remindedAt, remindAt])
  @@index([groupId, eventAt])
  @@map("activities")
}

model ActivityRegistration {
  activityId Int      @map("activity_id")
  userId     String   @map("user_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([activityId, userId])
  @@map("activity_registrations")
}

model FaqEntry {
  id        Int      @id @default(autoincrement())
  groupId   String   @map("group_id")
  keyword   String
  answer    String
  creatorId String   @map("creator_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([groupId, keyword])
  @@index([groupId, updatedAt])
  @@map("faq_entries")
}

model GroupTodo {
  id          Int       @id @default(autoincrement())
  groupId     String    @map("group_id")
  displayId   Int       @map("display_id")
  creatorId   String    @map("creator_id")
  assigneeId  String?   @map("assignee_id")
  content     String
  dueAt       DateTime? @map("due_at")
  remindAt    DateTime? @map("remind_at")
  remindedAt  DateTime? @map("reminded_at")
  completedAt DateTime? @map("completed_at")
  completedBy String?   @map("completed_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([groupId, displayId])
  @@index([groupId, completedAt, dueAt])
  @@index([completedAt, remindedAt, remindAt])
  @@map("group_todos")
}
