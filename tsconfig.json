{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["bun", "node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "prisma.config.ts",
    "src/**/*.ts",
    "plugins/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
